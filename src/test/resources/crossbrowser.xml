<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org">
<suite> name="Qase UI Crossbrowser Sequential Suite" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryListener"/>
    </listeners>

    <test name="UI Tests - Google Chrome">
        <parameter name="xmlBrowser" value="chrome"/>
        <groups><run><include name="regression"/></run></groups>
        <packages><package name="tests.ui"/></packages>
    </test>

    <test name="UI Tests - Mozilla Firefox">
        <parameter name="xmlBrowser" value="firefox"/>
        <groups><run><include name="regression"/></run></groups>
        <packages><package name="tests.ui"/></packages>
    </test>

    <test name="UI Tests - Microsoft Edge">
        <parameter name="xmlBrowser" value="edge"/>
        <groups><run><include name="regression"/></run></groups>
        <packages><package name="tests.ui"/></packages>
    </test>
</suite>